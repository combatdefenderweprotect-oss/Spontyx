{
  "meta": {
    "name": "Spontyx Brand System v2",
    "based_on": "Premier League style reference",
    "version": "2.0"
  },
  "colors": {
    "primary": {
      "green": "#A8E65E",
      "purple": "#33003A",
      "black": "#111111",
      "white": "#F5F5F5"
    },
    "secondary": {
      "purple": "#6A1B9A",
      "green": "#00C853",
      "cyan": "#26C6DA",
      "orange": "#FFB300",
      "pink": "#F06292"
    },
    "gradients": {
      "primary": "linear-gradient(135deg, #33003A, #A8E65E)",
      "highlight": "linear-gradient(135deg, #A8E65E, #D7F27D)",
      "accent": "linear-gradient(135deg, #00C853, #26C6DA)"
    }
  },
  "typography": {
    "font_family": {
      "primary": [
        "Satoshi",
        "Inter",
        "General Sans",
        "sans-serif"
      ]
    },
    "scale": {
      "h1": {
        "size": "48px",
        "weight": 700,
        "lineHeight": "1.1",
        "letterSpacing": "-1px"
      },
      "h2": {
        "size": "36px",
        "weight": 700,
        "lineHeight": "1.1",
        "letterSpacing": "-0.5px"
      },
      "h3": {
        "size": "28px",
        "weight": 600,
        "lineHeight": "1.2"
      },
      "h4": {
        "size": "22px",
        "weight": 600,
        "lineHeight": "1.3"
      },
      "body_large": {
        "size": "18px",
        "weight": 400,
        "lineHeight": "1.5"
      },
      "body": {
        "size": "16px",
        "weight": 400,
        "lineHeight": "1.6"
      },
      "small": {
        "size": "14px",
        "weight": 400,
        "lineHeight": "1.5"
      },
      "caption": {
        "size": "12px",
        "weight": 500,
        "letterSpacing": "0.5px"
      }
    },
    "usage": {
      "buttons": {
        "weight": 600,
        "transform": "uppercase"
      },
      "scores": {
        "weight": 700,
        "size": "32px"
      },
      "labels": {
        "weight": 500,
        "uppercase": true
      }
    },
    "detailed_rules": {
      "primary_font": "Satoshi",
      "fallback_font": "Inter",
      "roles": {
        "display": "Satoshi Bold/Black",
        "ui": "Inter Regular/Medium"
      },
      "numbers": {
        "type": "tabular",
        "weight": "bold",
        "size": "28-36px"
      },
      "letter_spacing": {
        "headlines": "-1px",
        "labels": "+0.5px"
      },
      "buttons": {
        "transform": "uppercase",
        "weight": "600-700"
      }
    }
  },
  "spacing": {
    "scale": [
      "4px",
      "8px",
      "12px",
      "16px",
      "24px",
      "32px",
      "48px",
      "64px"
    ]
  },
  "ui": {
    "buttons": {
      "primary": {
        "bg": "#A8E65E",
        "text": "#111111",
        "radius": "8px",
        "hover": "scale(1.05) + glow"
      },
      "secondary": {
        "border": "#A8E65E",
        "bg": "transparent"
      }
    },
    "cards": {
      "bg": "#33003A",
      "radius": "12px",
      "shadow": "soft",
      "hover": "lift + glow"
    },
    "states": {
      "live": {
        "color": "#00C853",
        "effect": "pulse"
      },
      "countdown": {
        "color": "#FFB300"
      },
      "finished": {
        "color": "#999999"
      }
    }
  },
  "motion": {
    "duration": "200-400ms",
    "easing": "ease-out",
    "effects": {
      "xp": "upward burst",
      "correct": "green flash",
      "wrong": "red shake",
      "hover": "scale + glow"
    }
  },
  "game_modes": {
    "arena": {
      "theme": "purple"
    },
    "battle_royale": {
      "theme": "red-orange"
    },
    "leagues": {
      "theme": "green-gold"
    }
  }
}